{
  "cli": {
    "version": ">= 10.0.0",
    "requireCommit": true
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview2": {
      "android": {
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "preview3": {
      "developmentClient": true
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccount": "@credentials.json",
        "track": "internal",
        "changesNotSentForReview": true
      },
      "ios": {
        "appleId": "@appleId",
        "ascAppId": "@ascAppId"
      }
    }
  }
}
