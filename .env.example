# ============================================================================
# TELLBILL ENVIRONMENT CONFIGURATION
# ============================================================================
# This file documents all available environment variables for TellBill.
# Copy this file to .env or .env.local and fill in your actual values.
#
# NAMING CONVENTIONS:
#  - EXPO_PUBLIC_* variables are exposed to the frontend (React Native)
#  - Other variables are for backend only (Node.js/Express)
# ============================================================================

# ============================================================================
# 1. DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/tellbill_dev
NODE_ENV=development

# ============================================================================
# 2. BACKEND URL CONFIGURATION (Frontend Only)
# ============================================================================
# The frontend uses ONE of these to determine the backend URL:
#
# For PRODUCTION STANDALONE APK:
# Set EXPO_PUBLIC_BACKEND_URL to your hosted backend HTTPS URL
EXPO_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# For DEVELOPMENT on Expo Go (Mobile):
# Set EXPO_PUBLIC_BACKEND_IP to your development machine's IP address
# Find IP: Windows → ipconfig, Mac → ifconfig, Linux → hostname -I
# Example: EXPO_PUBLIC_BACKEND_IP=192.168.1.100
EXPO_PUBLIC_BACKEND_IP=

# For WEB DEVELOPMENT:
# Fallback to http://localhost:3000 (automatic, no configuration needed)

# ============================================================================
# 3. SUPABASE CONFIGURATION
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# 4. EXTERNAL SERVICES
# ============================================================================
OPENROUTER_API_KEY=sk-or-v1-xxxxx
GROQ_API_KEY=gsk_xxxxx
REVENUECAT_API_KEY=sk_live_xxxxx
REVENUECAT_WEBHOOK_SECRET=whsk_xxxxx

# ============================================================================
# 5. PAYMENT SERVICES
# ============================================================================
# Stripe (for subscription payments)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_SOLO_PRICE_ID=price_xxxxx
STRIPE_PROFESSIONAL_PRICE_ID=price_xxxxx
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ============================================================================
# 6. EMAIL SERVICE
# ============================================================================
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@tellbill.app

# ============================================================================
# 7. COMMUNICATION SERVICES
# ============================================================================
# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Intercom (In-app chat support)
INTERCOM_APP_ID=xxxxx
INTERCOM_SECRET_KEY=xxxxx
INTERCOM_ACCESS_TOKEN=xxxxx

# ============================================================================
# 8. GOOGLE OAUTH (Frontend only)
# ============================================================================
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_REDIRECT_URL=exp://expo-redirect
GOOGLE_OAUTH_CLIENT_SECRET=xxxxx

# ============================================================================
# 9. SECURITY & JWT
# ============================================================================
JWT_SECRET=generate-secure-random-32-char-string
JWT_REFRESH_SECRET=generate-secure-random-32-char-string

# ============================================================================
# 10. SERVER CONFIGURATION
# ============================================================================
PORT=3000
SERVER_PORT=3000

# ============================================================================
# 11. FRONTEND APP CONFIGURATION
# ============================================================================
EXPO_PUBLIC_APP_URL=https://tellbill.app
ALLOWED_DOMAINS=tellbill.app,api.tellbill.app,*.tellbill.app

# ============================================================================
# 12. ERROR TRACKING (Optional)
# ============================================================================
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# App Version
APP_VERSION=1.0.0
