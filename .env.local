# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ============================================================================
# This file is for LOCAL DEVELOPMENT ONLY with Expo Go on mobile devices.
# It overrides production .env settings for dev purposes.
#
# ⚠️  IMPORTANT: Never commit this file (already in .gitignore)
# ⚠️  IMPORTANT: Update EXPO_PUBLIC_BACKEND_IP with your machine's IP address
# ============================================================================

NODE_ENV=development

# ============================================================================
# BACKEND URL FOR LOCAL DEVELOPMENT
# ============================================================================
# Use EXPO_PUBLIC_BACKEND_IP to point Expo Go on mobile to your dev machine
# 
# To find your IP address:
#  - Windows: Open Command Prompt and run: ipconfig
#    Look for "IPv4 Address" under your active WiFi connection (e.g., 192.168.1.100)
#  - Mac: System Preferences → Network → Select WiFi → Copy "IP Address"
#  - Linux: Open terminal and run: hostname -I (use the IP on your local network)
#
# REPLACE WITH YOUR ACTUAL IP ADDRESS:
# Example: EXPO_PUBLIC_BACKEND_IP=192.168.1.100
EXPO_PUBLIC_BACKEND_URL=https://tellbill-api.onrender.com

# DO NOT SET EXPO_PUBLIC_BACKEND_URL in development
# (it will override EXPO_PUBLIC_BACKEND_IP which is needed for mobile Expo Go)

