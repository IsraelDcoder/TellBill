# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION - STANDALONE APK/AAB
# ============================================================================
# This file is for production builds of TellBill (Standalone APK, AAB, etc.)
#
# ⚠️  CRITICAL:
#  1. The frontend uses EXPO_PUBLIC_BACKEND_URL to find the backend
#  2. EXPO_PUBLIC_BACKEND_IP is IGNORED in production builds
#  3. Must use HTTPS for production
#
# For Web Development: Web uses localhost automatically (no config needed)
# For Expo Go Dev Mobile: Use .env.local with EXPO_PUBLIC_BACKEND_IP instead
# ============================================================================

# ============================================================================
# DATABASE (PostgreSQL on Supabase)
# ============================================================================
DATABASE_URL=postgresql://postgres.uwlxzwvggvqqsbgukjsz:Thisismytellbill@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# ============================================================================
# PRODUCTION BACKEND URL - CRITICAL FOR APK
# ============================================================================
# This is the ONLY URL the standalone APK will use to connect to the backend
# Must be HTTPS and accessible from anywhere
# Examples:
#  - https://your-backend.onrender.com
#  - https://api.tellbill.app
#  - https://api.yourdomain.com
#
# ⚠️  DO NOT USE LOCALHOST OR LOCAL IP IN PRODUCTION
https://tellbill-api.onrender.com

# ============================================================================
# FRONTEND URL
# ============================================================================
EXPO_PUBLIC_APP_URL=https://tellbill.app

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=3000
SERVER_PORT=3000

