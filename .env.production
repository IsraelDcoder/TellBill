# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# For TellBill on Render.com
# ========================================

# ========================================
# DATABASE (PostgreSQL on Supabase - FREE!)
# ========================================
DATABASE_URL=postgresql://postgres:ThisisTellBill21@db.uwlxzwvggvqqsbgukjsz.supabase.co:5432/postgres

# ========================================
# FRONTEND & BACKEND URLS
# ========================================
# Using Render direct URL - more reliable than Cloudflare proxy
EXPO_PUBLIC_APP_URL=https://tellbill.app
EXPO_PUBLIC_BACKEND_URL=https://api.tellbill.app

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=production
PORT=3000

# ========================================
# SECURITY & AUTHENTICATION
# ========================================
# JWT Secrets (Generated securely, do not share)
# See RENDER_DEPLOYMENT_GUIDE.md for generation instructions
JWT_SECRET=dkWIzVVz9q3D7yiXkohBZi6RhjLNhjMFGiZDlnUwzSoWCmhz78Qcf7wVHN0ozimen2wxxEF4StpMjATCnnYg2g==
JWT_REFRESH_SECRET=RR2z9qfJOypBgsT5HiM0gYV4kIs3UINcA5mhqXEgwF+ZV7Ta545X5NkrcBhKTEEzXCzQ/YBGPbCUJ/TJda7itA==

# CORS Configuration
# Must match your production domains
ALLOWED_DOMAINS=tellbill.app,api.tellbill.app,www.tellbill.app,app.tellbill.app

# Error Tracking (Optional but recommended)
# SENTRY_DSN is now in the SENTRY section below

# ========================================
# EMAIL SERVICE - RESEND
# ========================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=***SET_IN_RENDER_ENVIRONMENT***
RESEND_FROM_EMAIL=noreply@tellbill.app

# ========================================
# AI/LLM SERVICES (OPTIONAL)
# ========================================
# OpenRouter API (for LLM features)
OPENROUTER_API_KEY=***SET_IN_RENDER_ENVIRONMENT***

# Groq API (fast LLM inference)
GROQ_API_KEY=***SET_IN_RENDER_ENVIRONMENT***

# ========================================
# PAYMENT PROCESSING - STRIPE
# ========================================
# Live Keys (stored securely in Render environment variables)
# DO NOT commit these! Set in Render Dashboard environment
STRIPE_SECRET_KEY=***SET_IN_RENDER_ENVIRONMENT***
STRIPE_PUBLISHABLE_KEY=***SET_IN_RENDER_ENVIRONMENT***
STRIPE_WEBHOOK_SECRET=***SET_IN_RENDER_ENVIRONMENT***

# Plan/Product IDs (Get from Stripe Products page)
STRIPE_SOLO_PRICE_ID=price_1A2B3C4D5E6F7G8H
STRIPE_PROFESSIONAL_PRICE_ID=price_2X9Y8Z7W6V5U4T3S

# ========================================
# REVENUECAT - SUBSCRIPTION MANAGEMENT
# ========================================
# Get API keys from: https://dashboard.revenuecat.com/settings/api-keys
# Public key: Used in client app for purchase requests
# Secret key: Used on server for webhook verification
REVENUECAT_SECRET_KEY=***SET_IN_RENDER_ENVIRONMENT***
REVENUECAT_PUBLIC_KEY=***SET_IN_RENDER_ENVIRONMENT***
# ✅ This goes in Expo .env for app to use
EXPO_PUBLIC_REVENUECAT_API_KEY=***SET_IN_EAS_BUILD_SECRETS***

# ========================================
# GOOGLE OAUTH - ACCOUNT AUTHENTICATION
# ========================================
# Get from Google Cloud Console: https://console.cloud.google.com/
# CRITICAL: Used for token verification to prevent account takeover
GOOGLE_CLIENT_ID=***SET_IN_RENDER_ENVIRONMENT***
GOOGLE_CLIENT_SECRET=***SET_IN_RENDER_ENVIRONMENT***
GOOGLE_REDIRECT_URI=https://api.tellbill.app/api/auth/google/callback

# ========================================
# SENTRY - ERROR TRACKING & MONITORING
# ========================================
# Get DSN from: https://sentry.io/ (create account and project)
# Used for production error tracking, alerting, and performance monitoring
SENTRY_DSN=***SET_IN_RENDER_ENVIRONMENT***
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ========================================
# DEPLOYMENT INSTRUCTIONS
# ========================================
# 1. Update DATABASE_URL with Render PostgreSQL connection string
# 2. Keep JWT_SECRET and JWT_REFRESH_SECRET secure (randomly generated)
# 3. Add STRIPE_WEBHOOK_SECRET from Stripe dashboard
# 4. Add RESEND_API_KEY from Resend dashboard
# 5. Paste all values into Render Web Service environment variables
# 6. Deploy and run migrations: npm run db:push
# 7. See RENDER_DEPLOYMENT_GUIDE.md for detailed instructions
